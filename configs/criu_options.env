# CRIU and CUDA checkpoint option defaults.
#
# These values are sourced by the experiment scripts and helper libraries.
# Keep this file simple: use shell variables only, no command execution.

# CRIU binary and sudo wrapper.
CRIU_BIN="${CRIU_BIN:-criu}"
CRIU_SUDO="${CRIU_SUDO:-sudo}"

# NVIDIA CUDA checkpoint utility.
#
# Some environments expose CUDA process checkpoint control through this command.
# The helper scripts will check whether it exists before attempting CUDA runs.
CUDA_CHECKPOINT_BIN="${CUDA_CHECKPOINT_BIN:-cuda-checkpoint}"

# CRIU log verbosity.
#
# Common CRIU log levels:
#   1 = only errors
#   2 = warnings
#   3 = informational logs
#   4 = debug logs
#
# Use 4 for experiments because failed CUDA checkpoint/restore attempts need
# detailed logs.
CRIU_LOG_LEVEL="${CRIU_LOG_LEVEL:-4}"

# Shell-job mode.
#
# This is often useful when checkpointing a process launched from a shell script.
# The helper library appends this only when CRIU_SHELL_JOB=1.
CRIU_SHELL_JOB="${CRIU_SHELL_JOB:-1}"

# Leave the original process running after dump.
#
# For the main checkpoint/restore benchmark, this should normally be 0.
#
# If set to 1, CRIU will attempt to leave the dumped process running after
# checkpointing. That is useful for some debugging scenarios, but not for the
# normal restore benchmark because it can create duplicate benchmark processes.
CRIU_LEAVE_RUNNING="${CRIU_LEAVE_RUNNING:-0}"

# Track memory pages.
#
# Disabled by default. This repo's first experiments measure full checkpoint
# cost rather than incremental checkpointing.
CRIU_TRACK_MEM="${CRIU_TRACK_MEM:-0}"

# TCP-established support.
#
# Disabled by default because the benchmark should not rely on TCP sockets.
CRIU_TCP_ESTABLISHED="${CRIU_TCP_ESTABLISHED:-0}"

# File lock support.
CRIU_FILE_LOCKS="${CRIU_FILE_LOCKS:-1}"

# Link remap support.
CRIU_LINK_REMAP="${CRIU_LINK_REMAP:-1}"

# External terminal handling.
#
# Keep disabled for the first implementation because benchmark stdout/stderr are
# redirected to files.
CRIU_EXT_TTY="${CRIU_EXT_TTY:-0}"

# Restore detached.
#
# If set to 1, CRIU restore returns after creating the restored task.
# The scripts wait for the benchmark's done marker to determine completion.
CRIU_RESTORE_DETACHED="${CRIU_RESTORE_DETACHED:-1}"

# CRIU timeout safety.
#
# These are script-level timeout values, not CRIU built-in options.
CRIU_DUMP_TIMEOUT_SECONDS="${CRIU_DUMP_TIMEOUT_SECONDS:-120}"
CRIU_RESTORE_TIMEOUT_SECONDS="${CRIU_RESTORE_TIMEOUT_SECONDS:-120}"

# CUDA checkpoint mode.
#
# Supported values for the helper scripts:
#
#   auto
#     Try CUDA-aware CRIU path first, while still checking for cuda-checkpoint.
#
#   criu-plugin
#     Use CRIU directly and rely on the CRIU CUDA plugin.
#
#   cuda-checkpoint-wrapper
#     Use cuda-checkpoint before/after CRIU dump/restore when the helper script
#     supports that path.
#
# Start with auto unless debugging a specific path.
CUDA_CHECKPOINT_MODE="${CUDA_CHECKPOINT_MODE:-auto}"

# Whether CUDA checkpoint helper failures should abort immediately.
CUDA_CHECKPOINT_STRICT="${CUDA_CHECKPOINT_STRICT:-1}"

# Whether to collect nvidia-smi before and after dump/restore.
COLLECT_NVIDIA_SMI="${COLLECT_NVIDIA_SMI:-1}"

# Whether to calculate checkpoint image directory size after dump.
COLLECT_CHECKPOINT_SIZE="${COLLECT_CHECKPOINT_SIZE:-1}"

# Additional user-provided CRIU dump and restore options.
#
# Keep empty by default. Advanced debugging can set these from the shell:
#
#   EXTRA_CRIU_DUMP_ARGS="--manage-cgroups ignore"
#   EXTRA_CRIU_RESTORE_ARGS="--manage-cgroups ignore"
EXTRA_CRIU_DUMP_ARGS="${EXTRA_CRIU_DUMP_ARGS:-}"
EXTRA_CRIU_RESTORE_ARGS="${EXTRA_CRIU_RESTORE_ARGS:-}"