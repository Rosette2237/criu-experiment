# Small matrix-size sweep for CUDA checkpoint/restore experiments.
#
# This sweep is intentionally conservative. Use it after the single-GPU
# checkpoint/restore experiment succeeds for MATRIX_SIZE=1024.

# Space-separated matrix sizes.
#
# Approximate explicit GPU matrix allocation:
#   N=512  -> 3 MiB
#   N=1024 -> 12 MiB
#   N=2048 -> 48 MiB
#   N=4096 -> 192 MiB
#
# Actual GPU memory usage is higher because of CUDA context and driver overhead.
MATRIX_SIZES="${MATRIX_SIZES:-512 1024 2048 4096}"

# Repeated kernel iterations for each matrix size.
#
# Keep this high enough that there is time to checkpoint in the middle.
SWEEP_ITERATIONS="${SWEEP_ITERATIONS:-60}"

# CUDA block size.
SWEEP_BLOCK_SIZE="${SWEEP_BLOCK_SIZE:-16}"

# Sleep between iterations.
#
# This makes checkpoint timing easier and gives the orchestration script a stable
# window to dump the process after the progress marker reaches the target.
SWEEP_SLEEP_MS_BETWEEN_ITERATIONS="${SWEEP_SLEEP_MS_BETWEEN_ITERATIONS:-100}"

# Checkpoint each run after this iteration.
#
# The sweep script may override this per-size if needed, but this is the default.
SWEEP_CHECKPOINT_AFTER_ITERATION="${SWEEP_CHECKPOINT_AFTER_ITERATION:-20}"

# Correctness checking.
SWEEP_VERIFY="${SWEEP_VERIFY:-1}"
SWEEP_VERIFY_SAMPLES="${SWEEP_VERIFY_SAMPLES:-64}"

# Single-GPU default.
export CUDA_VISIBLE_DEVICES="${CUDA_VISIBLE_DEVICES:-0}"
SWEEP_CUDA_DEVICE="${SWEEP_CUDA_DEVICE:-0}"

# Timeouts.
SWEEP_WAIT_TIMEOUT_SECONDS="${SWEEP_WAIT_TIMEOUT_SECONDS:-120}"
SWEEP_RESTORE_WAIT_TIMEOUT_SECONDS="${SWEEP_RESTORE_WAIT_TIMEOUT_SECONDS:-300}"