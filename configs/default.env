# Default experiment configuration.
#
# Scripts source this file first, then source more specific config files such as:
#
#   configs/single_gpu.env
#   configs/matrix_sweep_small.env
#   configs/criu_options.env
#
# You can also override most values from the shell before running a script:
#
#   MATRIX_SIZE=2048 ITERATIONS=80 ./scripts/02_run_cuda_baseline.sh

# Repository layout
REPO_ROOT="${REPO_ROOT:-$(pwd)}"
BUILD_DIR="${BUILD_DIR:-${REPO_ROOT}/build}"
BIN_DIR="${BIN_DIR:-${BUILD_DIR}/bin}"

# Binaries
CUDA_BENCH_BIN="${CUDA_BENCH_BIN:-${BIN_DIR}/matmul_bench}"
CPU_BASELINE_BIN="${CPU_BASELINE_BIN:-${BIN_DIR}/cpu_sleep_loop}"

# Output directories
RESULTS_DIR="${RESULTS_DIR:-${REPO_ROOT}/results}"
RAW_RESULTS_DIR="${RAW_RESULTS_DIR:-${RESULTS_DIR}/raw}"
PARSED_RESULTS_DIR="${PARSED_RESULTS_DIR:-${RESULTS_DIR}/parsed}"
LOGS_DIR="${LOGS_DIR:-${RESULTS_DIR}/logs}"
FIGURES_DIR="${FIGURES_DIR:-${RESULTS_DIR}/figures}"
CHECKPOINT_ROOT="${CHECKPOINT_ROOT:-${REPO_ROOT}/checkpoint-images}"
TMP_DIR="${TMP_DIR:-${REPO_ROOT}/tmp}"

# CUDA benchmark defaults
CUDA_DEVICE="${CUDA_DEVICE:-0}"
MATRIX_SIZE="${MATRIX_SIZE:-1024}"
ITERATIONS="${ITERATIONS:-60}"
BLOCK_SIZE="${BLOCK_SIZE:-16}"
SLEEP_MS_BETWEEN_ITERATIONS="${SLEEP_MS_BETWEEN_ITERATIONS:-100}"
VERIFY="${VERIFY:-1}"
VERIFY_SAMPLES="${VERIFY_SAMPLES:-64}"

# CPU baseline defaults
CPU_ITERATIONS="${CPU_ITERATIONS:-120}"
CPU_SLEEP_MS="${CPU_SLEEP_MS:-500}"

# Checkpoint timing
CHECKPOINT_AFTER_ITERATION="${CHECKPOINT_AFTER_ITERATION:-20}"
WAIT_TIMEOUT_SECONDS="${WAIT_TIMEOUT_SECONDS:-120}"
RESTORE_WAIT_TIMEOUT_SECONDS="${RESTORE_WAIT_TIMEOUT_SECONDS:-300}"

# Marker files
CUDA_READY_FILE="${CUDA_READY_FILE:-/tmp/criu-experiment-matmul.ready}"
CUDA_PROGRESS_FILE="${CUDA_PROGRESS_FILE:-/tmp/criu-experiment-matmul.progress}"
CUDA_DONE_FILE="${CUDA_DONE_FILE:-/tmp/criu-experiment-matmul.done}"

CPU_READY_FILE="${CPU_READY_FILE:-/tmp/criu-experiment-cpu.ready}"
CPU_PROGRESS_FILE="${CPU_PROGRESS_FILE:-/tmp/criu-experiment-cpu.progress}"
CPU_DONE_FILE="${CPU_DONE_FILE:-/tmp/criu-experiment-cpu.done}"

# Tool paths
MAKE_BIN="${MAKE_BIN:-make}"
NVCC_BIN="${NVCC_BIN:-nvcc}"
CC_BIN="${CC_BIN:-gcc}"
PYTHON_BIN="${PYTHON_BIN:-python3}"
CRIU_BIN="${CRIU_BIN:-criu}"
CUDA_CHECKPOINT_BIN="${CUDA_CHECKPOINT_BIN:-cuda-checkpoint}"
NVIDIA_SMI_BIN="${NVIDIA_SMI_BIN:-nvidia-smi}"

# Build defaults
CUDA_ARCH="${CUDA_ARCH:-sm_80}"

# CRIU execution mode
#
# CRIU commonly requires elevated privileges. Keep this as sudo unless your VM is
# explicitly configured for rootless CRIU operation.
CRIU_SUDO="${CRIU_SUDO:-sudo}"

# Run ID.
#
# Scripts may override this with a more descriptive value.
RUN_ID="${RUN_ID:-$(date -u +%Y%m%dT%H%M%SZ)}"

# Runtime paths derived from RUN_ID
RUN_DIR="${RUN_DIR:-${RAW_RESULTS_DIR}/${RUN_ID}}"
CHECKPOINT_DIR="${CHECKPOINT_DIR:-${CHECKPOINT_ROOT}/${RUN_ID}}"

# Standard log/output files
ENV_JSON="${ENV_JSON:-${RUN_DIR}/env.json}"

CUDA_BASELINE_JSON="${CUDA_BASELINE_JSON:-${RUN_DIR}/cuda_baseline.json}"
CHECKPOINT_RESTORE_JSON="${CHECKPOINT_RESTORE_JSON:-${RUN_DIR}/checkpoint_restore.json}"
CPU_BASELINE_JSON="${CPU_BASELINE_JSON:-${RUN_DIR}/cpu_criu_baseline.json}"

CUDA_STDOUT_LOG="${CUDA_STDOUT_LOG:-${RUN_DIR}/cuda_program_stdout.log}"
CUDA_STDERR_LOG="${CUDA_STDERR_LOG:-${RUN_DIR}/cuda_program_stderr.log}"
CPU_STDOUT_LOG="${CPU_STDOUT_LOG:-${RUN_DIR}/cpu_program_stdout.log}"
CPU_STDERR_LOG="${CPU_STDERR_LOG:-${RUN_DIR}/cpu_program_stderr.log}"

CRIU_DUMP_LOG="${CRIU_DUMP_LOG:-${RUN_DIR}/criu_dump.log}"
CRIU_RESTORE_LOG="${CRIU_RESTORE_LOG:-${RUN_DIR}/criu_restore.log}"

NVIDIA_SMI_BEFORE="${NVIDIA_SMI_BEFORE:-${RUN_DIR}/nvidia_smi_before.txt}"
NVIDIA_SMI_DURING="${NVIDIA_SMI_DURING:-${RUN_DIR}/nvidia_smi_during.txt}"
NVIDIA_SMI_AFTER="${NVIDIA_SMI_AFTER:-${RUN_DIR}/nvidia_smi_after.txt}"

CHECKPOINT_SIZE_FILE="${CHECKPOINT_SIZE_FILE:-${RUN_DIR}/checkpoint_size.txt}"
TIMING_FILE="${TIMING_FILE:-${RUN_DIR}/checkpoint_timing.env}"

# Shell behavior
VERBOSE="${VERBOSE:-1}"