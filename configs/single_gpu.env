# Single-GPU configuration for the first CUDA checkpoint/restore experiments.
#
# This file is intentionally conservative. Use this before attempting multi-GPU
# experiments or large matrix-size sweeps.

# Restrict the benchmark process to one visible GPU.
#
# The CUDA program also receives --device "${CUDA_DEVICE}".
# With CUDA_VISIBLE_DEVICES=0, CUDA device 0 maps to the first visible GPU.
export CUDA_VISIBLE_DEVICES="${CUDA_VISIBLE_DEVICES:-0}"

# CUDA logical device index inside the visible device set.
CUDA_DEVICE="${CUDA_DEVICE:-0}"

# Conservative first-test CUDA workload.
MATRIX_SIZE="${MATRIX_SIZE:-1024}"
ITERATIONS="${ITERATIONS:-60}"
BLOCK_SIZE="${BLOCK_SIZE:-16}"
SLEEP_MS_BETWEEN_ITERATIONS="${SLEEP_MS_BETWEEN_ITERATIONS:-100}"

# Correctness checking.
VERIFY="${VERIFY:-1}"
VERIFY_SAMPLES="${VERIFY_SAMPLES:-64}"

# Checkpoint after the workload has completed several CUDA kernel iterations.
#
# This should be:
#   - greater than 0
#   - less than ITERATIONS
#   - late enough that CUDA has initialized and GPU memory is allocated
CHECKPOINT_AFTER_ITERATION="${CHECKPOINT_AFTER_ITERATION:-20}"

# Timeout while waiting for marker files and restored completion.
WAIT_TIMEOUT_SECONDS="${WAIT_TIMEOUT_SECONDS:-120}"
RESTORE_WAIT_TIMEOUT_SECONDS="${RESTORE_WAIT_TIMEOUT_SECONDS:-300}"