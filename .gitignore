# Temporary run state
tmp/
run/
*.ready
*.progress
*.done
*.json.tmp

# Python cache
__pycache__/
*.py[cod]
.pytest_cache/

# Virtual environments
.venv/
venv/
env/

# Editor and OS files
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# Local environment overrides
*.local.env
.env