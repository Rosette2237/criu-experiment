# Build artifacts
build/
*.o
*.obj
*.so
*.a
*.out
*.exe

# CUDA generated files
*.ptx
*.cubin
*.fatbin
*.sass
*.nsys-rep
*.qdrep
*.nvvp

# Runtime logs
*.log
*.err
*.out
*.pid

# Experiment result outputs
results/raw/*
results/parsed/*
results/logs/*
results/figures/*

# Keep result directory structure
!results/raw/.gitkeep
!results/parsed/.gitkeep
!results/logs/.gitkeep
!results/figures/.gitkeep

# CRIU checkpoint images
checkpoint-images/*
